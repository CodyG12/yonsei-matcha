---
const igHandle = "yonseimatcha"; // TODO: confirm the real Instagram handle
const contactEmail = "hello@yonseimatcha.com"; // TODO: confirm the real contact email
---

<footer>
  <div class="wrap">
    <a
      class="logo-link"
      href={import.meta.env.BASE_URL}
      aria-label="Yonsei Matcha home"
    >
      <img
        class="logo-img"
        src={`${import.meta.env.BASE_URL}images/logo-wordmark.svg`}
        alt="Yonsei Matcha — Kūpuna Kuahā"
        width="220"
        height="60"
        loading="lazy"
      />
    </a>
    <p>
      Your favorite matcha popup on O'ahu this summer. Locations vary, see
      Instagram for this week's stops.
    </p>
    <div class="foot-links">
      <a
        class="icon-link"
        href={`https://instagram.com/${igHandle}`}
        target="_blank"
        rel="noopener"
        aria-label="Instagram"
      >
        <img
          src={`${import.meta.env.BASE_URL}images/instagram.svg`}
          alt=""
          width="18"
          height="18"
          loading="lazy"
        />
      </a>
      <a class="icon-link" href={`mailto:${contactEmail}`} aria-label="Email">
        <img
          src={`${import.meta.env.BASE_URL}images/email.svg`}
          alt=""
          width="18"
          height="18"
          loading="lazy"
        />
      </a>
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 58.8px 0 42px;
    text-align: center;
  }

  footer .logo-link {
    display: inline-flex;
    justify-content: center;
    margin-bottom: 12.6px;
  }

  footer .logo-img {
    height: 33.6px;
    width: auto;
    margin: 0 auto;
  }

  footer p {
    font-size: 13.65px;
    opacity: 0.6;
    margin-top: 6.3px;
  }

  footer .foot-links {
    display: flex;
    align-items: center;
    gap: 21px;
    justify-content: center;
    margin-top: 16.8px;
    font-size: 13.65px;
    font-weight: 700;
  }

  footer .foot-links a {
    text-decoration: none;
    opacity: 0.7;
  }

  footer .icon-link {
    display: inline-flex;
    align-items: center;
  }

  footer .icon-link img {
    width: 18.9px;
    height: 18.9px;
  }
</style>
