---
import { Image } from 'astro:assets';
import marketSign from '../assets/images/market-sign-matcha.jpg';
import marketPrep from '../assets/images/market-prep.jpg';
import strawberryMatcha from '../assets/images/strawberry-matcha.jpg';
import matchaHojichaPair from '../assets/images/matcha-hojicha-pair.jpg';

const igHandle = 'yonseimatcha'; // TODO: confirm the real Instagram handle
const placeholderCount = 4; // remaining empty tiles until more photos are added
---
<section class="section">
  <div class="wrap">
    <div class="follow reveal">
      <div class="kicker">Stay in the loop</div>
      <h2>Follow along on Instagram</h2>
      <p>Weekly market schedules, new specials, and pop-up announcements go up there first.</p>
      <div class="ig-grid">
        <Image src={marketSign} alt="Yonsei Matcha market sign with a fresh matcha latte" width={320} height={320} loading="lazy" />
        <Image src={marketPrep} alt="Preparing drinks at the Yonsei Matcha market table" width={320} height={320} loading="lazy" />
        <Image src={strawberryMatcha} alt="Iced strawberry matcha latte topped with a dried strawberry" width={320} height={320} loading="lazy" />
        <Image src={matchaHojichaPair} alt="A hojicha latte and a strawberry matcha latte side by side" width={320} height={320} loading="lazy" />
        {Array.from({ length: placeholderCount }).map(() => <div aria-hidden="true"></div>)}
      </div>
      <a class="btn btn-primary" href={`https://instagram.com/${igHandle}`} target="_blank" rel="noopener">
        @{igHandle} →
      </a>
    </div>
  </div>
</section>

<style>
  .follow {
    background: var(--ink);
    color: var(--cream);
    border-radius: var(--radius-soft);
    padding: 68px 24px;
    text-align: center;
  }

  .follow .kicker {
    color: var(--mint);
  }

  .follow h2 {
    color: var(--cream);
    font-size: clamp(28px, 4vw, 40px);
    margin-top: 8px;
  }

  .follow p {
    opacity: 0.75;
    max-width: 40ch;
    margin: 14px auto 0;
    line-height: 1.6;
  }

  .ig-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    max-width: 520px;
    margin: 34px auto 0;
  }

  .ig-grid img,
  .ig-grid div {
    aspect-ratio: 1;
    border-radius: 14px;
  }

  .ig-grid img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ig-grid div {
    background: linear-gradient(135deg, var(--mint) 0%, var(--teal-deep) 100%);
    opacity: 0.5;
  }

  .ig-grid div:nth-of-type(2n) {
    opacity: 0.75;
  }

  .follow :global(.btn-primary) {
    margin-top: 30px;
    background: var(--mint);
    color: var(--ink);
  }
</style>
